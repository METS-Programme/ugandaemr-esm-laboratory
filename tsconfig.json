{
  "compilerOptions": {
    "esModuleInterop": true,
    "module": "esnext",
    "allowSyntheticDefaultImports": true,
    "jsx": "react",
    "skipLibCheck": true,
    "moduleResolution": "node",
    "lib": [
      "dom",
      "es5",
      "scripthost",
      "es2015",
      "es2015.promise",
      "es2016.array.include",
      "es2018",
      "es2020",
      "es2021",
      "es2022"
    ],
    "resolveJsonModule": true,
    "noEmit": true,
    "target": "esnext",
    "skipDefaultLibCheck": true
  },
  "exclude": [
    "node_modules/@openmrs/esm-framework/node_modules",
    "node_modules/@ohri/openmrs-esm-ohri-commons-lib/node_modules"
  ]
}
